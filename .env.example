NODE_ENV=development
APP_VERSION=1.1.0

# Backend
PORT=3005
DB_PATH=./data/uptime.db

# Alerting (backend)
ALERT_FROM_EMAIL=uptime@kukana.local
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Frontend dev server (Vite)
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5175
VITE_API_PROXY_TARGET=http://127.0.0.1:3005

# Docker / cloudflared
TUNNEL_TOKEN=

# Docker / smtp-relay
SMTP_RELAY_HOST=
SMTP_RELAY_USERNAME=
SMTP_RELAY_PASSWORD=
SMTP_ALLOWED_SENDER_DOMAINS=*